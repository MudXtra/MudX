@using Microsoft.JSInterop

<div @key="_id" style="margin-left: -8px; margin-bottom: 8px; width: 240px; height: 240px; border-radius: var(--mud-default-borderradius);">
    <ins class="adsbygoogle"
         style="display:inline-block;width:240px;height:240px"
         data-ad-client="ca-pub-9521363170451553"
         data-ad-slot="3422015816"></ins>
</div>

@code {
    private string _id = Guid.NewGuid().ToString();

    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", "(adsbygoogle = window.adsbygoogle || []).push({});");
        }
    }
}
