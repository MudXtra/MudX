@page "/docs/securitycode"
@using MudX.Docs.SecurityCode
@using MudX.Docs.Examples

<PageTitle>Security Code</PageTitle>

<DocsPage>
    <DocsPageHeader>
        <Description>
            A segmented input control for entering verification codes, such as two-factor authentication tokens or access codes.
            Typically, you would use <CodeInline>MudXSecurityCode</CodeInline> to display a series of text fields that match a 
            customizable pattern (e.g., <CodeInline>####</CodeInline> or <CodeInline>##-##</CodeInline>). Each placeholder accepts 
            numeric, alphabetic, symbolic, or any <c>UTF-8</c> character types based on your configuration. 
        </Description>
    </DocsPageHeader>

    <DocsPageSection Title="Basic Usage">
        <Description>
            The default settings of <CodeInline>MudXSecurityCode</CodeInline> include a numeric pattern of 4 digits. You
            can change the pattern by using the <CodeInline Tag="false">Pattern</CodeInline> parameter, and you can change the Placeholders
            used to display the pattern by using the individual Placeholder parameters (e.g., 
            <CodeInline Tag="false">PlaceholderNumeric(#)</CodeInline>, <CodeInline Tag="false">PlaceholderAlpha(A)</CodeInline>, 
            <CodeInline Tag="false">PlaceholderAlphaNumeric(?)</CodeInline>, <CodeInline Tag="false">PlaceholderSpecial(@@)</CodeInline>,
            and <CodeInline Tag="false">PlaceholderAny(*)</CodeInline>).
        </Description>
        <ChildContent>
            <SectionContent Codes="@SecurityCodeBasicExampleCode.Files">
                <SecurityCodeBasicExample />
            </SectionContent>
        </ChildContent>
    </DocsPageSection>

    <DocsPageSection Title="Orientation">
        <Description>
            There are several different orientation styles that can be applied to the <CodeInline>MudXSecurityCode</CodeInline> control.
            By default the orientation is horizontal. This can be altered by using the <CodeInline Tag="false">Horizontal</CodeInline>
            parameter. You can also use the <CodeInline Tag="false">Margin</CodeInline> parameter to change the margin
            from normal/none (42px square) to dense (32px square). <CodeInline Tag="false">Spacing</CodeInline> controls the gap
            between each Code box.
        </Description>
        <ChildContent>
            <SectionContent Codes="@SecurityCodeOrientationExampleCode.Files">
                <SecurityCodeOrientationExample />
            </SectionContent>
        </ChildContent>
    </DocsPageSection>

    <DocsPageSection Title="Styling">
        <Description>
            Optional style options include <CodeInline Tag="false">Variant</CodeInline> to change the editable Code boxes, 
            and <CodeInline Tag="false">ReadOnlyVariant</CodeInline> to change the read-only Code boxes. <CodeInline Tag="false">
            Underline</CodeInline> controls whether the editable Code boxes have their input underlined or not. <CodeInline Tag="false">
            Password</CodeInline> controls whether the editable Code boxes are masked or not.
        </Description>
        <ChildContent>
            <SectionContent Codes="@SecurityCodeStylingExampleCode.Files">
                <SecurityCodeStylingExample />
            </SectionContent>
        </ChildContent>
    </DocsPageSection>

</DocsPage>

@code {
    private static string __title__ = "Security Code";
}