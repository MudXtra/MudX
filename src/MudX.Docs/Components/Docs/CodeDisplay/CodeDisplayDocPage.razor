@page "/docs/codedisplay"
@using MudX.Docs.Examples

<PageTitle>Code Syntax Display</PageTitle>

<DocsPage>
    <DocsPageHeader>
        <Description>
            A new componenet <CodeInline>MudXCodeDisplay</CodeInline> will display programatic code using Prism.js syntax highlighter. A number of
            themes are included to choose from as well as languages, multiple codefiles, line numbers, matching braces, invisibles, and copy to clipboard.
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="2">
                    <MudButton Color="Color.Primary" OnClick="@((e) => _expandedLanguages = !_expandedLanguages)">
                        @(_expandedLanguages ? "Collapse Languages" : "Expand Languages")
                    </MudButton>
                    <MudCollapse Expanded="_expandedLanguages">
                        <MudDivider />
                        <MudGrid>
                            @foreach (var language in _languageNames)
                            {
                                <MudItem xs="12" sm="6" md="4" lg="3">
                                    <CodeInline Tag="false">@language</CodeInline>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudCollapse>
                </MudStack>
                <MudStack Spacing="2">
                    <MudButton Color="Color.Primary" OnClick="@((e) => _expandedThemes = !_expandedThemes)">
                        @(_expandedThemes ? "Collapse Themes" : "Expand Themes")
                    </MudButton>
                    <MudCollapse Expanded="_expandedThemes">
                        <MudDivider />
                        <MudGrid>
                            @foreach (var theme in _themes)
                            {
                                <MudItem xs="12" sm="6" md="4" lg="3">
                                    <CodeInline>@theme</CodeInline>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudCollapse>
                </MudStack>
            </MudStack>
        </Description>
    </DocsPageHeader>

    <DocsPageSection Title="Basic Usage">
        <Description>
            You would normally put it inside your <CodeInline>MainLayout</CodeInline> but it is
            not required. Nor does it require any additional configuration or propeties to start working.
        </Description>
        <ChildContent>
            <SectionContent Codes="@BreadcrumbsBasicExampleCode.Files">
                <BreadcrumbsBasicExample />
            </SectionContent>
        </ChildContent>
    </DocsPageSection>

</DocsPage>

@code {
    private static string __title__ = "Code Syntax Display";

    private bool _expandedLanguages = false;
    private readonly List<string> _languageNames = new()
    {
        "HTML",
        "XML",
        "Markup",
        "SVG",
        "MathML",
        "SSML",
        "Atom",
        "RSS",
        "CSS",
        "C-like",
        "JavaScript",
        "Docker",
        "Markdown",
        "JSON",
        "Java",
        "Go",
        "PowerShell",
        "Python",
        "TypeScript",
        "PHP",
        "MongoDB",
        "C#",
        "ASP.NET",
        "Razor",
        "Ruby",
        "SQL",
        "YAML"
    };

    private bool _expandedThemes = false;
    private readonly List<string> _themes = new() { "Default", "Material Dark", "Material Light", "Okaidia", "Dark", "Funky", "Twilight", "Coy", "Solarized Light", "Tomorrow Night"};
}