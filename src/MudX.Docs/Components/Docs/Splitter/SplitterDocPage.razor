@page "/docs/splitter"
@using MudX.Docs.Splitter
@using MudX.Docs.Examples

<PageTitle>Splitter</PageTitle>

<DocsPage Headline="Splitter">
    <ChildContent>
        <DocsPageHeader>
            <Description>
                A basic splitter component to create resizable layouts. A fully customizable splitter with support for both horizontal and vertical 
                panels, as well as the ability to create your own <CodeInline Tag="false">SplitterTemplate</CodeInline>
            </Description>
        </DocsPageHeader>

        <DocsPageSection Title="Basic Usage">
            <Description>
                The default setting of <CodeInline>MudXSplitter</CodeInline> is for the <CodeInline Tag="false">Direction</CodeInline> 
                to be <CodeInline Tag="false">SplitterDirection.Horizontal</CodeInline>, and it uses an 8px wide splitter bar with 20px of margin 
                on each side between the panes. The <CodeInline Tag=false>StartSplitter</CodeInline> pane is the left side and the 
                <CodeInline Tag=false>EndSplitter</CodeInline> pane is the right side. 
            </Description>
            <ChildContent>
                <SectionContent Codes="@SplitterBasicExampleCode.Files">
                    <SplitterBasicExample />
                </SectionContent>
            </ChildContent>
        </DocsPageSection>

        <DocsPageSection Title="Vertical">
            <Description>
                It is as simple as setting <CodeInline Tag="false">Direction</CodeInline> to <CodeInline Tag="false">SplitterDirection.Vertical</CodeInline> 
                to use it as a vertical splitter. The <CodeInline Tag=false>StartSplitter</CodeInline> pane is the top side and the 
                <CodeInline Tag=false>EndSplitter</CodeInline> pane is the bottom side. 
            </Description>
            <ChildContent>
                <SectionContent Codes="@SplitterVerticalExampleCode.Files">
                    <SplitterVerticalExample />
                </SectionContent>
            </ChildContent>
        </DocsPageSection>

    </ChildContent>
    <ApiContent>
        <ApiSection ApiJson="MudXSplitter.api.json" />
    </ApiContent>

</DocsPage>

@code {
#pragma warning disable CS0414
    private static string __title__ = "Splitter";
#pragma warning restore CS0414
}