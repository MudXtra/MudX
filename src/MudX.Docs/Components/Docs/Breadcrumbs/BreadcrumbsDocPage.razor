@page "/docs/breadcrumbs"
@using MudX.Docs.Breadcrumbs

<PageTitle>Breadcrumbs</PageTitle>

<DocsPage>
    <DocsPageHeader>
        <Description>
            Extends <CodeInline>MudBreadcrumb</CodeInline> to automatically listen to route changes and update 
            the breadcrumbs to a label and optional route. It is best placed inside a <CodeInline>MainLayout</CodeInline>.            
        </Description>
    </DocsPageHeader>

    <DocsPageSection Title="Basic Usage">
        <Description>
            You would normally put it inside your <CodeInline>MainLayout</CodeInline> but it is
            not required.
        </Description>
        <SectionContent>
            <BreadcrumbsBasicExample />
        </SectionContent>
    </DocsPageSection>

    <DocsPageSection Title="Customization">
        <Description>
            Most settings carry over from the <CodeInline>MudBreadcrumb</CodeInline> component. 
            Obviously <CodeInline>Items</CodeInline>, <CodeInline>ItemTemplate</CodeInline>, 
            and <CodeInline>Icons</CodeInline> do not transfer.
        </Description>
        <SectionContent>
            <BreadcrumbsSettingsExample />
        </SectionContent>
    </DocsPageSection>

    <DocsPageSection Title="Collapsed">
        <Description>
            By setting the <CodeInline>MaxItems</CodeInline> parameter you can automatically 
            collapse the breadcrumbs when it exceeds a number of items.
        </Description>
        <SectionContent>
            <BreadcrumbsSettingsExample />
        </SectionContent>
    </DocsPageSection>

</DocsPage>