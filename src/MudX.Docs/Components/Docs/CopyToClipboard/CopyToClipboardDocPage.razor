@page "/docs/copytoclipboard"
@using MudX.Docs.CopyToClipboard
@using MudX.Docs.Examples

<PageTitle>Copy To Clipboard</PageTitle>

<DocsPage>
    <ChildContent>
        <DocsPageHeader>
            <Description>
                A new componenet <CodeInline>MudXCopyToClipboard</CodeInline> will provide a fast and easy way to copy text directly to the clipboard
                using browser tools.
            </Description>
        </DocsPageHeader>

        <DocsPageSection Title="Basic Usage">
            <Description>
                You can put a <CodeInline>MudXCopyToClipboard</CodeInline> anywhere inside a page or component. It will not generate anything in the DOM
                but make available one parameter, <CodeInline Tag="false">Snackbar</CodeInline>, that defaults to false. You have one exposed method,
                <CodeInline Tag="false">CopyToClipboardAsync</CodeInline> that will copy the supplied parameter text to the clipboard. If <CodeInline Tag="false">
                    Snackbar
                </CodeInline> is true it will show a snackbar with a success/failure message. In all cases it will return a <CodeInline Tag="false">
                    CopyResult
                </CodeInline> object with a <CodeInline Tag="false">Success</CodeInline> property that indicates if the copy was successful.
            </Description>
            <ChildContent>
                <SectionContent Codes="@CopyToClipboardBasicExampleCode.Files">
                    <CopyToClipboardBasicExample />
                </SectionContent>
            </ChildContent>
        </DocsPageSection>

        <DocsPageSection Title="Even Easier Usage">
            <Description>
                If you do not need the Snackbar or CopyResult returned from the component <CodeInline>IJSRuntime</CodeInline> contains an extension
                method so long as you have MudX in your <CodeInline Tag=false>using</CodeInline> or <CodeInline Tag=false>_Imports</CodeInline>.
                So inject IJsRuntime as you normally would like <CodeInline Tag=false>@@inject IJSRuntime _jsRuntime</CodeInline> and
                then after the first render you can execute <CodeInline Tag=false>_jsRuntime.CopyToClipboard(text_to_copy);</CodeInline>
                that will return a string indicating <CodeInline Tag=false>success</CodeInline> or the error message received.
            </Description>
            <ChildContent></ChildContent>
        </DocsPageSection>

    </ChildContent>
    <ApiContent>
        <ApiSection ApiJson="MudXCopyToClipboard.api.json" />
    </ApiContent>

</DocsPage>

@code {
#pragma warning disable CS0414
    private static string __title__ = "Copy To Clipboard";
#pragma warning restore CS0414
}