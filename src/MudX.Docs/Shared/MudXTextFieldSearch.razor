@inherits MudComponentBase

@if (_openState.Value)
{
    <MudAutocomplete @ref="_autoComplete" @bind-Value="@_searchItem" ResetValueOnEmptyText="true"
                     @bind-Value:after="@(() => SelectSearchResult())" MaxHeight="480" 
                     T="NavItem" SearchFunc="Search" AdornmentIcon="@string.Empty"
                     Variant="Variant.Outlined" Placeholder="Search..." Style="@Style"
                     Clearable="true" Modal="true" Class="@Class">
        <ItemTemplate Context="e">
            <MudText Color="Color.Primary">@e.Title</MudText>
        </ItemTemplate>
    </MudAutocomplete>
}

