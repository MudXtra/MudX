@inherits MudComponentBase

<MudStack>
    <MudTextField hidden="@(!_openState.Value)" 
                  Class="@Classname" 
                  Style="@Style"
                  Variant="Variant.Outlined" 
                  Placeholder="Search..." 
                  ValueChanged="@((string query) => Search(query))" />
    <MudPopover Open="PopoverOpen" AnchorOrigin="Origin.BottomLeft" RelativeWidth="DropdownWidth.Relative" MaxHeight="480">
        <MudList T="string">
            @foreach (var item in _searchResults)
            {
                <MudListItem OnClick="@(() => SelectSearchResult(item))">
                    <MudText Color="Color.Primary">@item</MudText>
                </MudListItem>
            }
        </MudList>
    </MudPopover>
</MudStack>

