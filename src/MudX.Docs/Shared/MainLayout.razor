@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="CustomThemes.SilverTheme" />
<MudDialogProvider BackdropClick="false" CloseOnEscapeKey="true" CloseButton="true" />
<MudSnackbarProvider />
<MudPopoverProvider />
<MudXProvider />

<MudLayout>
    <MudAppBar Elevation="4" Fixed=true>
        <MudIconButton Color="Color.Inherit" Icon="@Icons.Material.Outlined.Menu" Edge="Edge.Start" aria-label="Toggle Drawer" OnClick="@(() => _drawer = !_drawer)" />
        <MudButton Class="ml-2" Href="/" Variant="Variant.Text">
            <MudImage Src="/_content/MudX.Docs/images/MudX_Transparent_Logo.png" Alt="An image of the MudX logo!"
                      Style="width: 48px; height: 48px;" Class="mr-5 ml-n2" />
            <MudText Typo="Typo.h3" Class="mudx-outlined-text mr-5">MudX</MudText>
            <MudText Typo="Typo.h4" Class="mb-n1"> for MudBlazor</MudText>
        </MudButton>    
        <MudSpacer />
        <MudTooltip Text="Search the Documentation">
            <MudIconButton Color="Color.Inherit" Target="_blank" Icon="@Icons.Material.Outlined.Search" aria-label="Search" OnClick="@(() => _searchOpen = true)" />
        </MudTooltip>
        <MudDivider Vertical="true" />
            <MudTooltip Text="Try MudX Online">
            <MudIconButton Color="Color.Inherit" Target="_blank" Icon="@Icons.Material.Outlined.PlayCircleOutline" aria-label="Run MudX Code Snippets" Href="https://try.arctechonline.tech" />
        </MudTooltip>
        <MudDivider Vertical="true" />
        <MudTooltip Text="Theme Creator">
            <MudIconButton Color="Color.Inherit" Target="_blank" Icon="@Icons.Material.Outlined.ColorLens" aria-label="Theme Creator" Href="https://themes.arctechonline.tech" />
        </MudTooltip>
        <MudDivider Vertical="true" />
        <MudTooltip Text="MudBlazor Primary Site">
            <MudIconButton Color="Color.Inherit" Target="_blank" Icon="@Icons.Custom.Brands.MudBlazor" aria-label="MudBlazor Primary Site" Href="https://mudblazor.com" />
        </MudTooltip>
        <MudDivider Vertical="true" />
        <MudTooltip Text="Toggle Dark Mode">
            <MudIconButton Color="Color.Inherit" Edge="Edge.End" aria-label="Toggle Dark Mode" Icon="@(!_isDarkMode ? Icons.Material.Outlined.WbSunny : Icons.Material.Outlined.NightsStay)"
                           OnClick="@(() => _isDarkMode = !_isDarkMode)" />
        </MudTooltip>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawer" ClipMode="DrawerClipMode.Docked" Variant="DrawerVariant.Persistent" Class="pt-4 pa-2">
        <MainDrawer />
    </MudDrawer>    
    <MudMainContent Class="pt-15 pa-4">
        <ErrorBoundary>
            <ChildContent>
                <MudXBreadcrumbs />
                @Body
            </ChildContent>
        </ErrorBoundary>
    </MudMainContent>
</MudLayout>

<MudOverlay Visible="@_searchOpen" Absolute ZIndex="1600" Style="position: fixed; top: 64px; right: 50%;">
    <MudTextField hidden="@(!_searchOpen)" Variant="Variant.Outlined" Style="width: 350px" Placeholder="Search..." ValueChanged="@((string query) => Search(query))" />
</MudOverlay>

<CascadingValue Name="IsDarkTheme" Value="@_isDarkMode" IsFixed="false">

</CascadingValue>

@code {
    private bool _isDarkMode = false;
    private bool _drawer = true;
    private bool _searchOpen = false;

    private void Search(string query) 
    {
        Console.WriteLine(query);
    }
}