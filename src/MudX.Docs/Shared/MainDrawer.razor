@using Microsoft.AspNetCore.Components.Routing
@using System.Text.Json;
@using MudX.Docs.Data
@using MudX.Utilities
@inject NavigationManager NavManager

<MudTextField Class="my-2 background-textbox" Value="@_searchTerm" ValueChanged="@((string s) => OnSearchTextChanged(s))" 
              Placeholder="Search" Variant="Variant.Filled" Immediate="true" Clearable 
              UserAttributes="@(new Dictionary<string, object> { { "autocomplete", $"mudx-disabled-{Guid.NewGuid()}" } })" />
<MudNavMenu Class="mud-height-full mt-2">
    @foreach (var nav in _filteredNavList!)
    {
        @RenderNavItem(nav)
    }
</MudNavMenu>
<MudSpacer />
<div style="margin-left: -8px;margin-bottom: 8px;width: 240px;height: 240px;border-radius: var(--mud-default-borderradius);">
    <ins class="adsbygoogle"
         style="display:inline-block;width:240px;height:240px"
         data-ad-client="ca-pub-9521363170451553"
         data-ad-slot="3422015816"></ins>    
</div>
<MudText class="d-flex mx-auto" Typo="Typo.subtitle2">Version: @AssemblyInfo.Version</MudText>
@code {
    private string? _searchTerm;
    private List<NavItem> _navList = [];
    private Dictionary<int, NavItem> navItemsById = [];
    private List<NavItem> _filteredNavList = [];

    protected override void OnInitialized()
    {
        if (_navList.Count > 0)
        {
            return;
        }

        _navList = GeneratedNavList().OrderBy(x => x.Title).ToList();

        // Create a dictionary for fast lookups by NavItemId
        navItemsById = _navList.ToDictionary(x => x.NavItemId);

        OnSearchTextChanged(string.Empty);

    }

    private void OnSearchTextChanged(string searchTerm)
    {
        _searchTerm = searchTerm;

        // If search is empty, use the original ordered list
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            var navList = CombineNavList(_navList);
            _filteredNavList = navList
                .Where(x => x.IsActive && !x.ParentId.HasValue)
                .ToList();
            return;
        }

        // Find all items matching the search term
        var matchingItems = _navList
            .Where(x => x.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .ToHashSet();

        // Add all parent items of matching children
        var parentsToAdd = new HashSet<NavItem>();
        foreach (var item in matchingItems)
        {
            var currentItem = item;
            while (currentItem.ParentId.HasValue)
            {
                if (navItemsById.TryGetValue(currentItem.ParentId.Value, out var parent))
                {
                    parentsToAdd.Add(parent);
                    currentItem = parent;
                }
                else
                {
                    break;
                }
            }
        }

        // Combine all matching items
        var filteredList = matchingItems.Union(parentsToAdd).ToList();

        // Add children
        filteredList = CombineNavList(filteredList);

        // Final filtering for top-level active items
        _filteredNavList = filteredList
            .Where(x => x.IsActive && !x.ParentId.HasValue)
            .ToList();
    }

    private void NavigateTo(NavItem nav)
    {
        NavManager.NavigateTo(nav.Route);
    }

    RenderFragment RenderNavItem(NavItem nav)
    {
        return builder =>
        {
            if (nav.ChildNavItems.Any())
            {
                builder.OpenComponent<MudNavGroup>(3);
                builder.AddAttribute(4, "Title", nav.Title);
                builder.AddAttribute(5, "Icon", nav.Icon);

                builder.AddAttribute(6, "ChildContent", (RenderFragment)(childBuilder =>
                {
                    foreach (var child in nav.ChildNavItems)
                    {
                        childBuilder.AddContent(0, RenderNavItem(child));
                    }
                }));
                if (!nav.ParentId.HasValue)
                {
                    builder.AddAttribute(7, "Class", "parent-nav-item");
                }
                builder.AddAttribute(8, "ExpandIcon", Icons.Material.Filled.ExpandMore);
                builder.AddAttribute(9, "Expanded", true);
                builder.CloseComponent();
            }
            else
            {
                builder.OpenComponent<MudNavLink>(2);
                builder.AddAttribute(3, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, e => NavigateTo(nav)));
                builder.AddAttribute(4, "Icon", nav.Icon ?? string.Empty);
                builder.AddAttribute(5, "Match", NavLinkMatch.All);
                builder.AddAttribute(6, "Target", nav.IsNewWindow ? "_blank" : null);

                builder.AddAttribute(7, "ChildContent", (RenderFragment)(innerBuilder =>
                {
                    innerBuilder.AddContent(0, nav.Title);
                }));

                if (!nav.ParentId.HasValue)
                {
                    builder.AddAttribute(8, "Class", "parent-nav-item");
                }

                builder.CloseComponent();
            }
        };
    }

    private List<NavItem> GeneratedNavList()
    {
        var navItems = new List<NavItem> {
            // Parent Levels (Static)
            new NavItem() { NavItemId=90, Title="Home", Action="", OrderById=0, IsActive=true },
            new NavItem() { NavItemId=91, Title="Install", Action="installation", OrderById=1, IsActive=true },
            //new NavItem() { NavItemId=99, Title="About", Action="about", OrderById=99, IsActive=true },
        };

        // load generated docs
        var assembly = typeof(MudX.Docs.Shared.MainDrawer).Assembly;
        var resourceName = "MudX.Docs.wwwroot.nav-structure.json"; // Adjust if needed
        using var stream = assembly.GetManifestResourceStream(resourceName);
        using var reader = new StreamReader(stream!);
        var json = reader.ReadToEnd();
        var navStructure = JsonSerializer.Deserialize<List<NavItem>>(json) ?? [];
        navItems.AddRange(navStructure);

        return navItems
            .OrderBy(m => m.NavItemId)
            .ThenBy(m => !m.ParentId.HasValue ? int.MaxValue : m.ParentId) // Handle null ParentId which will ensure parent's are sorted by orderbyId
            .ThenBy(m => m.OrderById) // sort children by orderbyID
            .ToList();
    }

    private List<NavItem> CombineNavList(List<NavItem> navItems)
    {
        // Clear ChildNavItems property
        foreach (var navItem in navItems)
        {
            navItem.ChildNavItems.Clear();
        }
        // Populate ChildNavItems property
        foreach (var navItem in navItems)
        {
            if (navItem.ParentId.HasValue)
            {
                var parentNavItem = navItems.FirstOrDefault(n => n.NavItemId == navItem.ParentId);
                if (parentNavItem != null)
                {
                    parentNavItem.ChildNavItems.Add(navItem);
                }
            }
        }

        return navItems.OrderBy(x => x.OrderById).ToList();
    }

}