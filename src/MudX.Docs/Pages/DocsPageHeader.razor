@namespace MudX.Docs

<div class="docs-page-header mb-8">
    <MudText Typo="@Typo.h4">@Title</MudText>
    @if (Description != null)
    {
        <MudText Typo="@Typo.body1">@Description</MudText>
    }
    else
    {
        <MudText Typo="@Typo.body1">@DescriptionText</MudText>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Overview";
    [Parameter] public string DescriptionText { get; set; } = default!;
    [Parameter] public RenderFragment? Description { get; set; }
}