<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

    <Target Name="GenerateNavJsonBeforeBuild" BeforeTargets="PreBuildEvent"
            Inputs="@(ScriptFiles)"
            Outputs="@(ScriptFiles->'$(MSBuildThisFileDirectory)wwwroot\modules\%(Filename)%(Extension)')">
        <Message Importance="high" Text="======================================" />
        <Message Importance="high" Text="MudX.Generator: Starting MudX generation..." />

        <!-- Define paths -->
        <PropertyGroup>
            <GeneratorPath>$(MSBuildThisFileDirectory)..\MudX.Generator\MudX.Generator.csproj</GeneratorPath>
            <OutputPath>$(MSBuildThisFileDirectory)wwwroot</OutputPath>
            <ScriptsDirectory>$(MSBuildThisFileDirectory)Scripts</ScriptsDirectory>
        </PropertyGroup>

        <!-- Collect all .js files in Scripts directory -->
        <ItemGroup>
            <ScriptFiles Include="$(ScriptsDirectory)\**\*.js" />
        </ItemGroup>

        <!-- Build and run in one command -->
        <Exec Command="dotnet run --project &quot;$(GeneratorPath)&quot; --configuration Release -- &quot;$(OutputPath)&quot; &quot;$(ScriptsDirectory)&quot;"
              ConsoleToMSBuild="true" ContinueOnError="false" />

        <Message Importance="high" Text="MudX.Generator: Finished MudX generation..." />
        <Message Importance="high" Text="======================================" />
    </Target>

    <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>    
    
  <ItemGroup>
    <ProjectReference Include="..\MudX.DependsOn\MudX.DependsOn.csproj" />
  </ItemGroup>

</Project>
