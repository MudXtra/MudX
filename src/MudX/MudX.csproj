<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

        <Target Name="GenerateNavJsonBeforeBuild" BeforeTargets="PreBuildEvent">
        <Message Importance="high" Text="MudX.Generator: Starting MudX generation..." />

        <!-- Define paths -->
        <PropertyGroup>
            <GeneratorPath>$(MSBuildThisFileDirectory)..\MudX.Generator\MudX.Generator.csproj</GeneratorPath>
            <OutputPath>$(MSBuildThisFileDirectory)wwwroot\</OutputPath>
            <ScriptsDirectory>$(MSBuildThisFileDirectory)Scripts</ScriptsDirectory>
        </PropertyGroup>

        <!-- Build and run in one command - framework version independent -->
        <Exec Command="dotnet run --project &quot;$(GeneratorPath)&quot; --configuration Release -- &quot;$(OutputPath)&quot; &quot;$(ScriptsDirectory)&quot;" ConsoleToMSBuild="true" ContinueOnError="false" />

        <Message Importance="high" Text="MudX.Generator: Finished MudX generation..." />
    </Target>

        <ItemGroup>
          <Content Remove="wwwroot\mudxOutline.js" />
        </ItemGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MudX.DependsOn\MudX.DependsOn.csproj" />
  </ItemGroup>

</Project>
