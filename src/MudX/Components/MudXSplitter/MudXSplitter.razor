@namespace MudX

<div @ref="@_dragElement" 
     class="@SeparatorContainerClassname"
     style="@SeparatorContainerStylename"
     @onpointerdown="@OnPointerDown" @onpointerdown:preventDefault
     @onpointerup="@OnPointerUp" @onpointerup:preventDefault
     @onpointercancel="@OnPointerCancel" @onpointercancel:preventDefault
     @onlostpointercapture="@OnPointerCancel" @onlostpointercapture:preventDefault
     @onpointermove="@OnPointerMove" @onpointermove:preventDefault>
    <div class="@StartSplitterClassname">
        @if (StartSplitter != null)
        {
            @StartSplitter
        }
    </div>
    <div @ref="@_splitElement" class="@SeparatorClassname">
        @if (SeparatorTemplate != null)
        {
            @SeparatorTemplate
        }
        else
        {
            <div class="mudx-splitter-hr"></div>
        }
    </div>
    <div class="@EndSplitterClassname">
        @if (EndSplitter != null)
        {
            @EndSplitter
        }
    </div>
</div>                