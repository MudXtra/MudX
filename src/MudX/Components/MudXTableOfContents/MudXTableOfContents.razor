@using Microsoft.AspNetCore.Components.Routing
@namespace MudX
@inherits MudComponentBase

<div class="mudx-toc-document" @attributes="@UserAttributes">
    @if (HeaderContent != null)
    {
        @HeaderContent
    }

    @* This is the actual document that is tracked *@
    <MudContainer MaxWidth="MaxWidth.Large">
        <div id="@_tocId" class="mudx-toc-content">
            <CascadingValue Value="this" IsFixed="true">
                @ChildContent
            </CascadingValue>
        </div>
    </MudContainer>

    @if (ScrollToTopVisible)
    {
        <MudScrollToTop Visible="true" />
    }

    @if (FooterContent != null)
    {
        @FooterContent
    }
</div>

@* This is the clickable scroll tracking Table Of Contents *@
<MudDrawer Class="mudx-toc-nav-drawer"
           @bind-Open="_contentDrawerOpen"
           Breakpoint="@Breakpoint"
           Anchor="@Anchor"
           ClipMode="@DrawerClipMode"
           Elevation="@Elevation"
           Color="Color.Transparent">
    <MudText Typo="Typo.subtitle1" Class="mudx-toc-title" GutterBottom="true">
        @Headline
    </MudText>
    <div class="mudx-toc-nav-links">
        @foreach (var docSection in _sections.OrderBy(x => x.LevelSortingValue))
        {
            <MudNavLink @key="docSection.Id"
                        Match="NavLinkMatch.All"
                        Class="@GetNavLinkClass(docSection)"
                        OnClick="@(e => OnNavLinkClick(docSection._id))">
                @docSection.Title
            </MudNavLink>
        }
    </div>
</MudDrawer>