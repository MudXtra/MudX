@inherits MudComponentBase
@namespace MudX

<div id="@SectionId" class="@($"{Class} mudx-toc-section")" style="@Style" @attributes="@UserAttributes">
    @if (ChildContent != null)
    {
        <CascadingValue Value="this" IsFixed="true">
            @ChildContent
        </CascadingValue>
    }
</div>